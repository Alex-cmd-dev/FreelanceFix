generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique
  password_hash String
  first_name    String?
  last_name     String?
  created_at    DateTime @default(now()) @db.Timestamptz

  freelancer        Freelancer?
  client            Client?
  sent_messages     Message[]   @relation("SentMessages")
  received_messages Message[]   @relation("ReceivedMessages")

  @@map("users")
}

model Freelancer {
  id            String   @id @db.Uuid
  bio           String?
  portfolio_url String?
  hourly_rate   Decimal? @db.Decimal(10, 2)
  created_at    DateTime @default(now()) @db.Timestamptz

  user         User         @relation(fields: [id], references: [id], onDelete: Cascade)
  gigs         Gig[]
  brief_offers BriefOffer[]

  @@map("freelancers")
}

model Client {
  id               String   @id @db.Uuid
  company_name     String?
  spending_history Decimal  @default(0) @db.Decimal(12, 2)
  created_at       DateTime @default(now()) @db.Timestamptz

  user           User           @relation(fields: [id], references: [id], onDelete: Cascade)
  orders         Order[]
  project_briefs ProjectBrief[]

  @@map("clients")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz

  subcategories Subcategory[]

  @@map("categories")
}

model Subcategory {
  id          Int      @id @default(autoincrement())
  category_id Int
  name        String
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz

  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)
  gigs     Gig[]

  @@unique([category_id, name])
  @@map("subcategories")
}

enum PackageTier {
  Basic
  Standard
  Premium

  @@map("package_tier")
}

enum OrderStatus {
  Pending
  In_Progress
  Completed
  Cancelled

  @@map("order_status")
}

enum PaymentStatus {
  Pending
  Escrow
  Released
  Refunded

  @@map("payment_status")
}

model Gig {
  id             Int      @id @default(autoincrement())
  freelancer_id  String   @db.Uuid
  subcategory_id Int
  title          String
  description    String
  base_price     Decimal  @db.Decimal(10, 2)
  created_at     DateTime @default(now()) @db.Timestamptz

  freelancer  Freelancer  @relation(fields: [freelancer_id], references: [id], onDelete: Cascade)
  subcategory Subcategory @relation(fields: [subcategory_id], references: [id], onDelete: Restrict)
  packages    GigPackage[]

  @@map("gigs")
}

model GigPackage {
  id            Int         @id @default(autoincrement())
  gig_id        Int
  tier          PackageTier
  price         Decimal     @db.Decimal(10, 2)
  description   String
  delivery_days Int
  created_at    DateTime    @default(now()) @db.Timestamptz

  gig    Gig     @relation(fields: [gig_id], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([gig_id, tier])
  @@map("gig_packages")
}

model Order {
  id             Int         @id @default(autoincrement())
  client_id      String      @db.Uuid
  gig_package_id Int
  status         OrderStatus @default(Pending)
  total_amount   Decimal     @db.Decimal(10, 2)
  due_date       DateTime?   @db.Timestamptz
  created_at     DateTime    @default(now()) @db.Timestamptz

  client      Client     @relation(fields: [client_id], references: [id], onDelete: Restrict)
  gig_package GigPackage @relation(fields: [gig_package_id], references: [id], onDelete: Restrict)
  payment     Payment?
  review      Review?

  @@map("orders")
}

model Payment {
  id             Int           @id @default(autoincrement())
  order_id       Int           @unique
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus @default(Pending)
  payment_method String?
  processed_at   DateTime?     @db.Timestamptz
  created_at     DateTime      @default(now()) @db.Timestamptz

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Review {
  id         Int      @id @default(autoincrement())
  order_id   Int      @unique
  rating     Int
  comment    String?
  created_at DateTime @default(now()) @db.Timestamptz

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Message {
  id          Int      @id @default(autoincrement())
  sender_id   String   @db.Uuid
  receiver_id String   @db.Uuid
  content     String
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz

  sender   User @relation("SentMessages", fields: [sender_id], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiver_id], references: [id], onDelete: Cascade)

  @@map("messages")
}

model ProjectBrief {
  id          Int      @id @default(autoincrement())
  client_id   String   @db.Uuid
  title       String
  description String
  budget_min  Decimal? @db.Decimal(10, 2)
  budget_max  Decimal? @db.Decimal(10, 2)
  status      String   @default("Open")
  created_at  DateTime @default(now()) @db.Timestamptz

  client Client       @relation(fields: [client_id], references: [id], onDelete: Cascade)
  offers BriefOffer[]

  @@map("project_briefs")
}

model BriefOffer {
  id               Int      @id @default(autoincrement())
  project_brief_id Int
  freelancer_id    String   @db.Uuid
  offer_amount     Decimal  @db.Decimal(10, 2)
  description      String
  status           String   @default("Pending")
  created_at       DateTime @default(now()) @db.Timestamptz

  project_brief ProjectBrief @relation(fields: [project_brief_id], references: [id], onDelete: Cascade)
  freelancer    Freelancer   @relation(fields: [freelancer_id], references: [id], onDelete: Cascade)

  @@map("brief_offers")
}
