# Supabase Prisma Connection
# DATABASE_URL uses the transaction pooler (port 6543) — required for Prisma in serverless/pooled environments
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL uses the direct connection (port 5432) — used by prisma migrate and prisma db push
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

PORT=3001
